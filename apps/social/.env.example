# ============================================================
# NextAuth (Google OAuth)
# ============================================================
NEXTAUTH_SECRET=
NEXTAUTH_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated list of email domains allowed to sign in in addition to
# @figure.com (which is always allowed). Leave empty to lock sign-in to
# @figure.com only. Case-insensitive. Phase 17-01 Task 5.
# Example: highlandventures.io,partner.co
ALLOWED_EMAIL_DOMAINS=

# ============================================================
# Database (Vercel Postgres / Neon)
# ============================================================
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# ============================================================
# Cron
# ============================================================
CRON_SECRET=

# ============================================================
# External APIs
# ============================================================
ANTHROPIC_API_KEY=
TWITTERAPI_IO_API_KEY=
LATE_API_KEY=

# ============================================================
# Vercel KV (Redis)
# ============================================================
KV_REST_API_URL=
KV_REST_API_TOKEN=
