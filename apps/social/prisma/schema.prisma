// ============================================================
// UNIFIED ARTIFACT GRAPH (v3.0)
// Every tracked object (project, task, post, email, LC ticket, report,
// briefing, etc.) has a corresponding Artifact row. Module tables remain
// the source of truth for domain data; the graph is the cross-module spine.
// See .planning/phases/17-artifact-graph-foundation/17-01-PLAN.md
// ============================================================

enum ArtifactType {
  CAMPAIGN
  PROJECT
  SUB_PROJECT
  TASK
  SUBTASK
  MILESTONE
  POST
  EMAIL
  ASSET
  LC_TICKET
  REPORT
}

enum ArtifactModule {
  SOCIAL
  GTM
  EMAIL
  LC_REVIEW
  HUB
}

enum ArtifactRelationshipType {
  PARENT_OF
  CHILD_OF
  DEPENDS_ON
  RELATES_TO
  DERIVED_FROM
  REVIEWED_BY
  PUBLISHED_AS
}

model Artifact {
  id         String         @id @default(cuid())
  type       ArtifactType
  title      String
  parentId   String?
  ownerId    String?
  status     String?        // module-specific status (DRAFT, IN_PROGRESS, PUBLISHED, ...)
  module     ArtifactModule
  entityId   String         // FK into the module-specific table (cuid of the module row)
  metadata   Json?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  archivedAt DateTime?

  parent      Artifact?              @relation("ArtifactHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Artifact[]             @relation("ArtifactHierarchy")
  owner       User?                  @relation("artifactOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  sourceEdges ArtifactRelationship[] @relation("ArtifactEdgeSource")
  targetEdges ArtifactRelationship[] @relation("ArtifactEdgeTarget")

  // back-relations to module tables (for Prisma type safety, not used for lookups)
  post             Post?             @relation("postArtifact")
  gtmProject       GtmProject?       @relation("gtmProjectArtifact")
  gtmTask          GtmTask?          @relation("gtmTaskArtifact")
  gtmMoment        GtmMoment?        @relation("gtmMomentArtifact")
  emailCampaign    EmailCampaign?    @relation("emailCampaignArtifact")
  notionTaskInbox  NotionTaskInbox?  @relation("notionTaskArtifact")
  report           Report?           @relation("reportArtifact")
  homeTask         HomeTask?         @relation("homeTaskArtifact")
  intelligenceTask IntelligenceTask? @relation("intelligenceTaskArtifact")
  weeklyBriefing   WeeklyBriefing?   @relation("weeklyBriefingArtifact")

  @@unique([module, entityId]) // one artifact per module row
  @@index([type])
  @@index([module, type])
  @@index([parentId])
  @@index([ownerId])
  @@index([archivedAt])
  @@map("artifacts")
}

model ArtifactRelationship {
  id               String                   @id @default(cuid())
  sourceId         String
  targetId         String
  relationshipType ArtifactRelationshipType
  createdById      String?
  createdAt        DateTime                 @default(now())
  archivedAt       DateTime?

  source    Artifact @relation("ArtifactEdgeSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target    Artifact @relation("ArtifactEdgeTarget", fields: [targetId], references: [id], onDelete: Cascade)
  createdBy User?    @relation("artifactEdgeAuthor", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([sourceId, targetId, relationshipType])
  @@index([sourceId, relationshipType])
  @@index([targetId, relationshipType])
  @@index([archivedAt])
  @@map("artifact_relationships")
}
