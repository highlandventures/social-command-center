// ============================================================
// INTELLIGENCE TASKS & BRIEFINGS
// ============================================================

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DISMISSED
  SNOOZED
}

enum TaskSourceType {
  LISTENING
  EMAIL
  CALENDAR
  CAMPAIGN
  REPORT
  MANUAL
}

enum TaskPriority {
  CRITICAL    // Score 80-100: act now
  HIGH        // Score 60-79: act today
  MEDIUM      // Score 40-59: act this week
  LOW         // Score 0-39: when you get to it
}

enum UserRole {
  CMO
  CONTENT_STRATEGIST
  SOCIAL_MANAGER
  GROWTH_ANALYST
  KOL_MANAGER
  GENERAL
}

model IntelligenceTask {
  id              String          @id @default(cuid())
  title           String          // Action-oriented: "Reply to @journalist about HELOC"
  description     String?         // Additional context
  sourceType      TaskSourceType  // Where the signal came from
  sourceId        String?         // ID of the source record (listeningHitId, emailThreadId, etc.)
  sourceUrl       String?         // Direct link to the source
  actionType      String?         // Maps to Phase 15 ActionType (RESPOND/INTEL/OPPORTUNITY/CRISIS/FYI)
  suggestedAction String?         // What to do: "Draft a reply addressing their question about..."
  priorityScore   Int             @default(50)  // 0-100
  priority        TaskPriority    @default(MEDIUM)
  status          TaskStatus      @default(PENDING)
  assignedRole    UserRole        @default(GENERAL)
  dueDate         DateTime?
  context         Json?           // Structured context: related signals, sender info, etc.
  snoozedUntil    DateTime?
  completedAt     DateTime?
  dismissedAt     DateTime?
  dismissReason   String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Link back to briefing that generated this task
  briefingId      String?
  briefing        WeeklyBriefing? @relation(fields: [briefingId], references: [id])

  artifactId      String?         @unique
  artifact        Artifact?       @relation("intelligenceTaskArtifact", fields: [artifactId], references: [id], onDelete: SetNull)

  @@index([status, priorityScore])
  @@index([assignedRole, status])
  @@index([sourceType, sourceId])
  @@index([artifactId])
  @@map("intelligence_tasks")
}

model WeeklyBriefing {
  id              String    @id @default(cuid())
  weekStart       DateTime  // Monday of the briefing week
  role            UserRole  @default(GENERAL)
  summary         String    // AI-generated executive summary
  topPriorities   Json      // Array of top 3-5 priority items
  meetingsContext Json?     // Upcoming meetings with relevant context
  signalsSummary  Json?     // Aggregated signal counts by type
  campaignStatus  Json?     // In-flight campaign summaries
  generatedAt     DateTime  @default(now())
  generatedBy     String    @default("system") // "system" or userId
  artifactId      String?   @unique

  tasks    IntelligenceTask[]
  artifact Artifact?          @relation("weeklyBriefingArtifact", fields: [artifactId], references: [id], onDelete: SetNull)

  @@unique([weekStart, role])
  @@index([artifactId])
  @@map("weekly_briefings")
}

// ============================================================
// EMAIL CAMPAIGNS
// ============================================================

enum SubscriberStatus {
  ACTIVE
  UNSUBSCRIBED
  BOUNCED
  COMPLAINED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

enum EmailEventType {
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
  UNSUBSCRIBED
}

model EmailList {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscribers EmailSubscriber[]
  campaigns   EmailCampaign[]

  @@index([createdById])
  @@map("email_lists")
}

model EmailSubscriber {
  id        String           @id @default(cuid())
  listId    String
  email     String
  firstName String?
  lastName  String?
  status    SubscriberStatus @default(ACTIVE)
  metadata  Json?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  list   EmailList    @relation(fields: [listId], references: [id], onDelete: Cascade)
  sends  EmailSend[]
  events EmailEvent[]

  @@unique([listId, email])
  @@index([listId, status])
  @@index([email])
  @@map("email_subscribers")
}

model EmailTemplate {
  id          String   @id @default(cuid())
  name        String
  subject     String?
  htmlBody    String
  category    String?
  isStarter   Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaigns EmailCampaign[]

  @@index([createdById])
  @@map("email_templates")
}

model EmailCampaign {
  id           String         @id @default(cuid())
  name         String
  subject      String
  fromName     String?
  fromEmail    String?
  replyTo      String?
  listId       String
  templateId   String?
  htmlContent  String?
  status       CampaignStatus @default(DRAFT)
  scheduledFor DateTime?
  sentAt       DateTime?
  createdById  String
  artifactId   String?        @unique
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  list     EmailList      @relation(fields: [listId], references: [id])
  template EmailTemplate? @relation(fields: [templateId], references: [id])
  sends    EmailSend[]
  artifact Artifact?      @relation("emailCampaignArtifact", fields: [artifactId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([listId])
  @@index([artifactId])
  @@map("email_campaigns")
}

model EmailSend {
  id           String   @id @default(cuid())
  campaignId   String
  subscriberId String
  messageId    String?
  status       String   @default("QUEUED")
  sentAt       DateTime?
  error        String?
  createdAt    DateTime @default(now())

  campaign   EmailCampaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  subscriber EmailSubscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  events     EmailEvent[]

  @@unique([campaignId, subscriberId])
  @@index([campaignId, status])
  @@map("email_sends")
}

model EmailEvent {
  id           String         @id @default(cuid())
  sendId       String
  subscriberId String
  eventType    EmailEventType
  metadata     Json?
  occurredAt   DateTime       @default(now())

  send       EmailSend       @relation(fields: [sendId], references: [id], onDelete: Cascade)
  subscriber EmailSubscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@index([sendId])
  @@index([subscriberId, eventType])
  @@index([occurredAt])
  @@map("email_events")
}

// ============================================================
// NOTION TASK INBOX
// Tasks filed from Social Command → synced to Notion Task Inbox
// → Notion automation copies to main Marketing Tasks database
// ============================================================

model NotionTaskInbox {
  id               String   @id @default(cuid())
  userId           String
  title            String
  status                  String    @default("Not Started")   // Not Started, In Progress, Done, Ready for Compliance, On Hold
  flllcComplianceStatus   String    @default("Not Needed")    // FLLLC: Not Needed, Legal Review, Not Started, Comments Added, Comments Addressed, In Progress, Approved
  fmComplianceStatus      String    @default("Not Needed")    // FM: same options as FLLLC
  legalStatus             String?                              // Not Needed, Not Started, In Progress, Comments Added, Comments Addressed, Approved
  reviewPriority          String?                              // High, Medium, Low, Nice to have someday
  due                     DateTime?
  lcDueDate               DateTime?                            // L&C Due Date
  publishDate             DateTime?                            // Publish Date
  product                 String[]                             // Multi-select: 21 options
  channel                 String[]                             // Multi-select: 26 options
  audience                String[]                             // Multi-select: 10 options
  socialChannel           String[]                             // Multi-select: YT, LI, Twitter, FB, IG, Reddit
  company                 String[]                             // Multi-select: Figure, Figure Lending LLC (NY), etc.
  geo                     String[]                             // Multi-select: International, US (National), etc.
  editorialReviewStage    String?                              // Bill (create), Figure Editorial Review, Bill (Edit), Ready to Publish
  needComplianceApproval  Boolean   @default(false)
  archivedForCompliance   Boolean   @default(false)
  notes                   String?
  summary                 String?
  lexionUrl               String?                              // Lexion URL
  shortcutTicketUrl       String?                              // Shortcut Ticket URL
  filedBy                 String                               // Email of person who filed
  notionPageId     String?  // Set after synced to Notion
  syncedAt         DateTime? // Timestamp when synced to Notion
  artifactId       String?  @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  artifact Artifact? @relation("notionTaskArtifact", fields: [artifactId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([syncedAt])
  @@index([createdAt])
  @@index([artifactId])
  @@map("notion_task_inbox")
}

