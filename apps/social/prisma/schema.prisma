// Social Command Center — Prisma Schema
// Vercel Postgres + Prisma ORM
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// ============================================================
// AUTH & USERS
// ============================================================

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  avatarUrl    String?
  role         Role      @default(INTERNAL)
  invitedBy    String?
  createdAt    DateTime  @default(now())
  lastActiveAt DateTime?

  // Relations
  sessions           Session[]
  accountAccess      UserAccountAccess[]
  approvalsRequested ApprovalRequest[] @relation("approvalRequester")
  approvalsMade      ApprovalRequest[] @relation("reviewer")
  auditLogs          AuditLog[]
  posts              Post[]            @relation("createdBy")
  alertRules         AlertRule[]
  aiInsights         AIInsight[]
  tickets            Ticket[]
  copilotThreads     CopilotThread[]
  googleOAuth        GoogleOAuthToken?
  homeTasks          HomeTask[]
  notionTaskInbox    NotionTaskInbox[]
  gtmProjects        GtmProject[] @relation("gtmProjectOwner")
  gtmTasks           GtmTask[]    @relation("gtmTaskOwner")
  artifacts            Artifact[]             @relation("artifactOwner")
  artifactRelationships ArtifactRelationship[] @relation("artifactEdgeAuthor")

  @@map("users")
}

enum Role {
  ADMIN
  INTERNAL
  AGENCY
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================
// SOCIAL ACCOUNTS (X + Reddit)
// ============================================================

model Account {
  id             String    @id @default(cuid())
  platform       Platform
  accessToken    String // AES-256-GCM encrypted
  refreshToken   String? // AES-256-GCM encrypted
  tokenExpiresAt DateTime?
  platformUserId String
  username       String
  displayName    String?
  avatarUrl      String?
  connectedAt    DateTime  @default(now())
  isActive       Boolean   @default(true)
  isTest         Boolean   @default(false)

  // X (Twitter) subscription tier — affects character limits & features
  // "free" = 280 chars | "basic" = 280 chars | "premium" = 25K chars | "premium_plus" = 25K + Articles
  subscriptionTier String   @default("free") // free | basic | premium | premium_plus
  followerCount    Int?     // cached for quick access (synced from AccountMetrics)
  isVerified       Boolean  @default(false)

  // High-water mark for poll-mentions: the newest platform mention id we've processed.
  // Passed as sinceId to searchTweets on the next cron run so we only fetch genuinely
  // new mentions instead of redundantly re-fetching the top-20 window each time.
  lastMentionId      String?
  lastMentionSyncAt  DateTime?

  // Relations
  posts          Post[]
  postMetrics    PostMetrics[]
  accountMetrics AccountMetrics[]
  mentions       Mention[]
  inboxItems     InboxItem[]
  listeningHits  ListeningHit[]
  userAccess     UserAccountAccess[]
  aiInsights     AIInsight[]

  @@unique([platform, platformUserId])
  @@map("accounts")
}

enum Platform {
  X
  REDDIT
}

model UserAccountAccess {
  id        String   @id @default(cuid())
  userId    String
  accountId String
  grantedBy String?
  grantedAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([userId, accountId])
  @@map("user_account_access")
}

// ============================================================
// POSTS & SCHEDULING
// ============================================================

model Post {
  id             String      @id @default(cuid())
  accountId      String
  platform       Platform
  platformPostId String? // Null until published
  content        String
  contentType    ContentType @default(POST)
  threadId       String? // Self-ref for thread items
  threadPosition Int?
  status         PostStatus  @default(DRAFT)
  scheduledFor   DateTime?
  publishedAt    DateTime?
  createdById    String
  subreddit      String? // Reddit only
  flairId        String? // Reddit only
  articleTitle   String? // X Articles only
  notionPageId   String? // Notion page ID for L&C review integration
  artifactId     String?     @unique
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Relations
  account      Account           @relation(fields: [accountId], references: [id])
  createdBy    User              @relation("createdBy", fields: [createdById], references: [id])
  threadParent Post?             @relation("threadPosts", fields: [threadId], references: [id])
  threadPosts  Post[]            @relation("threadPosts")
  metrics      PostMetrics[]
  approvals    ApprovalRequest[]
  media        PostMedia[]
  artifact     Artifact?         @relation("postArtifact", fields: [artifactId], references: [id], onDelete: SetNull)

  @@index([accountId, status])
  @@index([scheduledFor])
  @@index([platformPostId])
  @@index([artifactId])
  @@map("posts")
}

model PostMedia {
  id        String   @id @default(cuid())
  postId    String?
  platform  Platform
  url       String   // Vercel Blob URL
  mimeType  String   // e.g. image/jpeg, image/png
  sizeBytes Int
  width     Int?
  height    Int?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  post Post? @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("post_media")
}

enum ContentType {
  POST
  THREAD
  ARTICLE
  COMMENT
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PENDING_APPROVAL
  APPROVED
  PUBLISHED
  FAILED
}

model PostMetrics {
  id        String   @id @default(cuid())
  postId    String
  accountId String
  fetchedAt DateTime @default(now())

  // X metrics
  impressions   Int @default(0)
  engagements   Int @default(0)
  likes         Int @default(0)
  retweets      Int @default(0)
  replies       Int @default(0)
  bookmarks     Int @default(0)
  quotes        Int @default(0) // quote-tweets — Phase 17-03; previously read from TwitterAPI.io but not persisted
  linkClicks    Int @default(0)
  profileClicks Int @default(0)

  // Reddit metrics
  upvotes      Int @default(0)
  downvotes    Int @default(0)
  commentCount Int @default(0)
  awards       Int @default(0)

  // Computed
  engagementRate Float @default(0)

  post    Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id])

  @@index([postId, fetchedAt])
  @@index([accountId, fetchedAt])
  @@map("post_metrics")
}

model AccountMetrics {
  id        String   @id @default(cuid())
  accountId String
  date      DateTime @db.Date

  followers  Int  @default(0)
  following  Int  @default(0)
  totalPosts Int  @default(0)
  karma      Int? // Reddit only

  account Account @relation(fields: [accountId], references: [id])

  @@unique([accountId, date])
  @@map("account_metrics")
}

// ============================================================
// MENTIONS & INBOX
// ============================================================

model Mention {
  id                String      @id @default(cuid())
  accountId         String
  platform          Platform
  platformMentionId String?
  authorUsername    String
  authorDisplayName String?
  content           String
  mentionType       MentionType
  sourceUrl         String?
  detectedAt        DateTime    @default(now())
  read              Boolean     @default(false)
  responded         Boolean     @default(false)

  account Account @relation(fields: [accountId], references: [id])

  @@index([accountId, detectedAt])
  @@map("mentions")
}

enum MentionType {
  MENTION
  REPLY
  QUOTE
  DM
}

model InboxItem {
  id            String    @id @default(cuid())
  accountId     String
  platform      Platform
  itemType      InboxType
  fromUsername  String
  content       String
  threadContext String?
  receivedAt    DateTime  @default(now())
  read          Boolean   @default(false)
  archived      Boolean   @default(false)
  replied       Boolean   @default(false)
  assignedTo    String?
  internalNotes String?

  account Account @relation(fields: [accountId], references: [id])

  @@index([accountId, receivedAt])
  @@index([read, archived])
  @@map("inbox_items")
}

enum InboxType {
  COMMENT
  DM
  MENTION
}

// ============================================================
// SOCIAL LISTENING
// ============================================================

model ListeningTopic {
  id                  String       @id @default(cuid())
  name                String
  description         String?
  createdById         String
  createdAt           DateTime     @default(now())
  active              Boolean      @default(true)
  pollingTier         PollingTier  @default(WARM)
  pollingTierOverride PollingTier?

  // When true, the scanner applies the strict content gate (1 high-confidence term OR 2+
  // ecosystem terms) that used to be triggered by topic names containing "kol". Explicit
  // flag so "general ecosystem" topics don't accidentally opt into the stricter filter.
  strictRelevance Boolean @default(false)

  queries    ListeningQuery[]
  hits       ListeningHit[]
  subreddits MonitoredSubreddit[]
  entities   BrandEntity[]

  @@map("listening_topics")
}

// ============================================================
// BRAND ONTOLOGY
// ------------------------------------------------------------
// Structured description of a brand/product/person the planner uses to generate
// search queries. One row per entity (brand, product, subsidiary, token, person).
// Editing an entity triggers a reconcile that rebuilds that entity's ListeningQuery
// rows so queries stay in sync with the ontology.
// ============================================================

model BrandEntity {
  id            String     @id @default(cuid())
  topicId       String
  kind          EntityKind
  canonicalName String
  aliases       String[]   @default([])
  tickers       String[]   @default([])
  xHandles      String[]   @default([])
  redditUsers   String[]   @default([])
  hashtags      String[]   @default([])

  // Ambiguity & noise control.
  // isAmbiguous=true → the canonical/alias terms are common English, so the planner
  // emits qualified queries like `("OPEN network") (qualifiers...)` instead of bare.
  isAmbiguous   Boolean    @default(false)
  qualifiers    String[]   @default([])
  negativeTerms String[]   @default([])

  // Per-entity knobs.
  minFaves  Int?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topic   ListeningTopic   @relation(fields: [topicId], references: [id], onDelete: Cascade)
  queries ListeningQuery[]

  @@index([topicId])
  @@map("brand_entities")
}

enum EntityKind {
  BRAND
  PRODUCT
  PERSON
  SUBSIDIARY
  TOKEN
}

// ============================================================
// DIAGNOSE LOG
// ------------------------------------------------------------
// Every call to listening.diagnose writes a row here. The log becomes the "things
// we thought we should capture" dataset — the highest-signal input for refining
// the ontology. NO_QUERY_MATCH rows are the gaps, BLOCKED_BY_NEGATIVE rows are
// the false-positive excludes. Resolved rows link back to the entity that closed
// the gap so we can measure how often the feedback loop actually fires.
// ============================================================

// ============================================================
// GLOBAL ALGO TERMS
// ------------------------------------------------------------
// Previously hardcoded arrays in listening-scanner.js (HIGH_CONFIDENCE_TERMS,
// ECOSYSTEM_TERMS). Moving to DB so operators can promote a token via the admin
// UI and have it apply to the next scan without a code deploy. Hardcoded lists
// remain as a resilience fallback when the DB is unreachable.
// ============================================================

model GlobalAlgoTerm {
  id             String       @id @default(cuid())
  term           String       // Lower-case, substring-matched against content
  kind           AlgoTermKind
  enabled        Boolean      @default(true)
  note           String?      // Why this was promoted; helpful for audit
  addedFromLogId String?      // DiagnoseLog.id that justified the addition (optional)
  createdById    String?
  createdAt      DateTime     @default(now())

  @@unique([term, kind])
  @@index([kind, enabled])
  @@map("global_algo_terms")
}

enum AlgoTermKind {
  HIGH_CONFIDENCE
  ECOSYSTEM
}

model DiagnoseLog {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  createdById     String?

  // Input — what the user pasted in
  url             String?
  tweetId         String?
  content         String?
  authorUsername  String?

  // Output of the decision tree
  outcome         String   // CAPTURED_AS_HIT | CAPTURED_AS_MENTION | WOULD_BE_CAPTURED | NO_QUERY_MATCH | BLOCKED_BY_NEGATIVE | INSUFFICIENT_INPUT
  matchedCount    Int      @default(0)
  blockedCount    Int      @default(0)
  resultJson      Json?    // Full diagnose() result for forensic inspection

  // Follow-up state — set when a user acts on the gap via the "Fix" buttons.
  resolvedEntityId String?
  resolvedAt       DateTime?
  resolutionNote   String?

  @@index([createdAt])
  @@index([outcome, createdAt])
  @@map("diagnose_logs")
}

enum PollingTier {
  HOT
  WARM
  COOL
  SCHEDULED
}

model ListeningQuery {
  id               String    @id @default(cuid())
  topicId          String
  platform         Platform
  queryString      String
  negativeKeywords String[]  @default([])
  subreddits       String[]  @default([])
  generatedBy      String    @default("manual") // "ai" | "manual"
  active           Boolean   @default(true)
  estDailyVolume   Int?
  estMonthlyCost   Float?
  totalHits        Int       @default(0)
  actionableHits   Int       @default(0)
  spamHits         Int       @default(0)
  dismissedHits    Int       @default(0)
  avgHeuristic     Float?
  lastEvaluatedAt  DateTime?

  // High-water mark for listening scans: the newest platform post id this query has seen.
  // Passed as sinceId so we don't re-scan the same top window on every cron tick.
  lastHitPlatformId String?
  lastHitSyncAt     DateTime?

  // Provenance: when this query was generated by the ontology planner, the entity it came
  // from and the template key (e.g. 'mention_sweep', 'ticker_sweep'). Hand-authored queries
  // leave both null. Lets us reconcile / replace planner queries safely.
  sourceEntityId String?
  sourceTemplate String?
  sourceEntity   BrandEntity? @relation(fields: [sourceEntityId], references: [id], onDelete: SetNull)

  topic ListeningTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  hits  ListeningHit[]

  @@index([sourceEntityId])
  @@map("listening_queries")
}

model ListeningHit {
  id                     String     @id @default(cuid())
  queryId                String
  topicId                String
  accountId              String?
  platform               Platform
  platformPostId         String?
  authorUsername         String
  authorDisplayName      String?
  authorProfileImageUrl  String?
  authorFollowersOrKarma Int?
  content                String
  sourceUrl              String?
  subreddit              String?
  parentThreadTitle      String?
  detectedAt             DateTime   @default(now())
  engagementCount        Int        @default(0)
  heuristicScore         Float      @default(0)
  aiRelevance            Relevance?
  sentiment              Sentiment?
  sentimentConfidence    Float?
  isActionable           Boolean    @default(false)
  dismissed              Boolean    @default(false)
  dismissedBy            String?
  dismissReason          String?
  routedToInboxItemId    String?

  // Phase 15: Signal Intelligence
  actionType           ActionType?    // AI-classified actionability
  authorTrustScore     Float?         // Composite author quality (0-1)
  authorEngagementRate Float?         // Cached: engagements / followers
  authorAccountAgeDays Int?           // Account age in days (if available)
  authorIsVerified     Boolean        @default(false)
  semanticRelevance    Float?         // AI semantic score (replaces pure keyword)

  query   ListeningQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)
  topic   ListeningTopic @relation(fields: [topicId], references: [id])
  account Account?       @relation(fields: [accountId], references: [id])

  @@index([topicId, detectedAt])
  @@index([sentiment, detectedAt])
  @@map("listening_hits")
}

enum Relevance {
  HIGH
  MEDIUM
  LOW
  SPAM
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum ActionType {
  RESPOND      // Needs a direct reply (mention, question, complaint)
  INTEL        // Competitive intelligence to catalog
  OPPORTUNITY  // Content or engagement opportunity
  CRISIS       // Negative sentiment needing immediate attention
  FYI          // Informational, no action needed
}

model MonitoredSubreddit {
  id            String  @id @default(cuid())
  topicId       String
  subredditName String
  suggestedBy   String  @default("manual")
  active        Boolean @default(true)
  avgDailyPosts Int?
  avgEngagement Float?

  topic   ListeningTopic     @relation(fields: [topicId], references: [id], onDelete: Cascade)
  metrics SubredditMetrics[]

  @@unique([topicId, subredditName])
  @@map("monitored_subreddits")
}

model SubredditMetrics {
  id          String   @id @default(cuid())
  subredditId String
  date        DateTime @db.Date

  subscribers   Int     @default(0)
  postsCount    Int     @default(0)
  commentsCount Int     @default(0)
  avgUpvotes    Float   @default(0)
  avgComments   Float   @default(0)
  topPostScore  Int     @default(0)
  topPostTitle  String?

  subreddit MonitoredSubreddit @relation(fields: [subredditId], references: [id], onDelete: Cascade)

  @@unique([subredditId, date])
  @@map("subreddit_metrics")
}

// ============================================================
// COMPETITORS
// ============================================================

model Competitor {
  id          String   @id @default(cuid())
  name        String
  createdById String
  createdAt   DateTime @default(now())

  accounts   CompetitorAccount[]
  keywords   CompetitorKeyword[]
  metrics    CompetitorMetrics[]
  posts      CompetitorPost[]
  amplifiers CompetitorAmplifier[]

  @@map("competitors")
}

model CompetitorAccount {
  id             String   @id @default(cuid())
  competitorId   String
  platform       Platform
  username       String
  platformUserId String?

  competitor Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@map("competitor_accounts")
}

model CompetitorKeyword {
  id           String @id @default(cuid())
  competitorId String
  keyword      String

  competitor Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@map("competitor_keywords")
}

model CompetitorMetrics {
  id           String   @id @default(cuid())
  competitorId String
  date         DateTime @db.Date

  followersX           Int   @default(0)
  followersReddit      Int   @default(0)
  karmaReddit          Int   @default(0)
  postsCount           Int   @default(0)
  avgEngagementRate    Float @default(0)
  mentionCount         Int   @default(0)
  sentimentPositivePct Float @default(0)
  shareOfVoicePct      Float @default(0)

  competitor Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@unique([competitorId, date])
  @@map("competitor_metrics")
}

model CompetitorPost {
  id             String   @id @default(cuid())
  competitorId   String
  platform       Platform
  platformPostId String
  content        String
  contentType    String   @default("POST") // POST, THREAD, ARTICLE
  authorUsername String
  postedAt       DateTime
  fetchedAt      DateTime @default(now())

  // Engagement metrics at time of fetch
  likes          Int   @default(0)
  retweets       Int   @default(0)
  replies        Int   @default(0)
  quotes         Int   @default(0)
  impressions    Int   @default(0)
  engagementRate Float @default(0)

  competitor Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@unique([competitorId, platformPostId])
  @@index([competitorId, postedAt])
  @@map("competitor_posts")
}

model CompetitorAmplifier {
  id                     String   @id @default(cuid())
  competitorId           String
  platform               Platform
  username               String
  platformUserId         String?
  displayName            String?
  avatarUrl              String?
  followersCount         Int      @default(0)
  amplificationType      String // comma-separated: "RETWEET,QUOTE,MENTION"
  interactionCount       Int      @default(0)
  engagementContribution Int      @default(0)
  firstSeenAt            DateTime @default(now())
  lastSeenAt             DateTime @default(now())

  competitor Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@unique([competitorId, platform, username])
  @@index([competitorId, interactionCount])
  @@map("competitor_amplifiers")
}

// ============================================================
// KOL TRACKING
// ============================================================

model KOL {
  id                      String           @id @default(cuid())
  name                    String
  platform                Platform
  username                String
  platformUserId          String?
  avatarUrl               String?
  bio                     String?
  location                String?
  verified                Boolean          @default(false)
  followingCount          Int?
  accountCreatedAt        DateTime?
  websiteUrl              String?
  profileSummary          String? // AI-generated JSON narrative
  profileSummaryUpdatedAt DateTime?
  profileEnrichedAt       DateTime? // Last API enrichment timestamp
  relationshipType        RelationshipType
  cohortId                String?
  compensationMonthly     Float?
  campaignDeliverables    Json?
  baselineFollowers       Int?
  baselineEngRate         Float?
  aiScore                 String? // A-F
  aiScoreRationale        String?
  aiScoreUpdatedAt        DateTime?
  addedBy                 String
  createdAt               DateTime         @default(now())
  active                  Boolean          @default(true)

  cohort      KOLCohort?      @relation(fields: [cohortId], references: [id])
  activations KOLActivation[]
  metrics     KOLMetrics[]

  @@map("kols")
}

enum RelationshipType {
  PAID_PARTNER
  ORGANIC_ADVOCATE
  ADVISOR
  PORTFOLIO_FOUNDER
  RETAIL_ANALYST
  COMPANY_EXEC
}

model KOLCohort {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdBy   String
  createdAt   DateTime @default(now())

  kols KOL[]

  @@map("kol_cohorts")
}

model KOLActivation {
  id                 String         @id @default(cuid())
  kolId              String
  platform           Platform
  activationType     ActivationType
  platformPostId     String?
  content            String?
  sourceUrl          String?
  postedAt           DateTime?
  detectedAt         DateTime       @default(now())
  detectionMethod    String?
  campaignId         String?
  sentiment          Sentiment?
  metricsAtDetection Json?
  metricsAt24h       Json?
  metricsAt48h       Json?
  metricsAt7d        Json?

  kol KOL @relation(fields: [kolId], references: [id], onDelete: Cascade)

  @@index([kolId, detectedAt])
  @@map("kol_activations")
}

enum ActivationType {
  DIRECT_MENTION
  RETWEET
  QUOTE_TWEET
  REPLY
  THREAD
  SUBREDDIT_POST
  COMMENT
  ORGANIC_ADVOCACY
}

model KOLMetrics {
  id        String   @id @default(cuid())
  kolId     String
  weekStart DateTime @db.Date

  followers                  Int     @default(0)
  engagementRateBrand        Float   @default(0)
  engagementRateBaseline     Float   @default(0)
  activationsCount           Int     @default(0)
  totalImpressionsEst        Int     @default(0)
  avgEngagementPerActivation Float   @default(0)
  sentimentPositivePct       Float   @default(0)
  followerGrowthCorrelation  Float   @default(0)
  aiScore                    String?
  costPerEngagement          Float?

  kol KOL @relation(fields: [kolId], references: [id], onDelete: Cascade)

  @@unique([kolId, weekStart])
  @@map("kol_metrics")
}

// ============================================================
// ALERTS & AI INSIGHTS
// ============================================================

model AlertRule {
  id          String  @id @default(cuid())
  createdById String
  name        String
  active      Boolean @default(true)
  conditions  Json // { topic, platform, relevance, sentiment, thresholds }
  actions     Json // { notify channels, assign_to, tag, priority }

  createdBy User @relation(fields: [createdById], references: [id])

  @@map("alert_rules")
}

model AIInsight {
  id             String      @id @default(cuid())
  accountId      String?
  userId         String?
  insightType    InsightType
  content        Json
  dataRangeStart DateTime?
  dataRangeEnd   DateTime?
  generatedAt    DateTime    @default(now())
  dismissed      Boolean     @default(false)
  dismissedBy    String?

  account Account? @relation(fields: [accountId], references: [id])
  user    User?    @relation(fields: [userId], references: [id])

  @@index([insightType, generatedAt])
  @@map("ai_insights")
}

enum InsightType {
  POST_DEBRIEF
  WEEKLY_SUMMARY
  DAILY_LISTENING_DIGEST
  WEEKLY_LANDSCAPE_REPORT
  OPTIMAL_SCHEDULE
  AUDIENCE_INSIGHT
  CONTENT_SUGGESTION
  PERFORMANCE_PATTERN
  COMPETITOR_STRATEGY
  AUDIENCE_QUESTION
  X_ANALYST_REPORT
  X_COCREATOR_CONTEXT
  X_COMPETITOR_AUDIT
}

