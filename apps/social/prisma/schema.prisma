// Social Command Center — Prisma Schema
// Vercel Postgres + Prisma ORM
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// ============================================================
// AUTH & USERS
// ============================================================

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  avatarUrl    String?
  role         Role      @default(INTERNAL)
  invitedBy    String?
  createdAt    DateTime  @default(now())
  lastActiveAt DateTime?

  // Relations
  sessions           Session[]
  accountAccess      UserAccountAccess[]
  approvalsRequested ApprovalRequest[] @relation("approvalRequester")
  approvalsMade      ApprovalRequest[] @relation("reviewer")
  auditLogs          AuditLog[]
  posts              Post[]            @relation("createdBy")
  alertRules         AlertRule[]
  aiInsights         AIInsight[]
  tickets            Ticket[]
  copilotThreads     CopilotThread[]

  @@map("users")
}

enum Role {
  ADMIN
  INTERNAL
  AGENCY
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================
// SOCIAL ACCOUNTS (X + Reddit)
// ============================================================

model Account {
  id             String    @id @default(cuid())
  platform       Platform
  accessToken    String // AES-256-GCM encrypted
  refreshToken   String? // AES-256-GCM encrypted
  tokenExpiresAt DateTime?
  platformUserId String
  username       String
  displayName    String?
  avatarUrl      String?
  connectedAt    DateTime  @default(now())
  isActive       Boolean   @default(true)
  isTest         Boolean   @default(false)

  // Relations
  posts          Post[]
  postMetrics    PostMetrics[]
  accountMetrics AccountMetrics[]
  mentions       Mention[]
  inboxItems     InboxItem[]
  listeningHits  ListeningHit[]
  userAccess     UserAccountAccess[]
  aiInsights     AIInsight[]

  @@unique([platform, platformUserId])
  @@map("accounts")
}

enum Platform {
  X
  REDDIT
}

model UserAccountAccess {
  id        String   @id @default(cuid())
  userId    String
  accountId String
  grantedBy String?
  grantedAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([userId, accountId])
  @@map("user_account_access")
}

// ============================================================
// POSTS & SCHEDULING
// ============================================================

model Post {
  id             String      @id @default(cuid())
  accountId      String
  platform       Platform
  platformPostId String? // Null until published
  content        String
  contentType    ContentType @default(POST)
  threadId       String? // Self-ref for thread items
  threadPosition Int?
  status         PostStatus  @default(DRAFT)
  scheduledFor   DateTime?
  publishedAt    DateTime?
  createdById    String
  subreddit      String? // Reddit only
  flairId        String? // Reddit only
  articleTitle   String? // X Articles only
  notionPageId   String? // Notion page ID for L&C review integration
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Relations
  account      Account           @relation(fields: [accountId], references: [id])
  createdBy    User              @relation("createdBy", fields: [createdById], references: [id])
  threadParent Post?             @relation("threadPosts", fields: [threadId], references: [id])
  threadPosts  Post[]            @relation("threadPosts")
  metrics      PostMetrics[]
  approvals    ApprovalRequest[]

  @@index([accountId, status])
  @@index([scheduledFor])
  @@index([platformPostId])
  @@map("posts")
}

enum ContentType {
  POST
  THREAD
  ARTICLE
  COMMENT
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PENDING_APPROVAL
  APPROVED
  PUBLISHED
  FAILED
}

model PostMetrics {
  id        String   @id @default(cuid())
  postId    String
  accountId String
  fetchedAt DateTime @default(now())

  // X metrics
  impressions   Int @default(0)
  engagements   Int @default(0)
  likes         Int @default(0)
  retweets      Int @default(0)
  replies       Int @default(0)
  bookmarks     Int @default(0)
  linkClicks    Int @default(0)
  profileClicks Int @default(0)

  // Reddit metrics
  upvotes      Int @default(0)
  downvotes    Int @default(0)
  commentCount Int @default(0)
  awards       Int @default(0)

  // Computed
  engagementRate Float @default(0)

  post    Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id])

  @@index([postId, fetchedAt])
  @@index([accountId, fetchedAt])
  @@map("post_metrics")
}

model AccountMetrics {
  id        String   @id @default(cuid())
  accountId String
  date      DateTime @db.Date

  followers  Int  @default(0)
  following  Int  @default(0)
  totalPosts Int  @default(0)
  karma      Int? // Reddit only

  account Account @relation(fields: [accountId], references: [id])

  @@unique([accountId, date])
  @@map("account_metrics")
}

// ============================================================
// MENTIONS & INBOX
// ============================================================

model Mention {
  id                String      @id @default(cuid())
  accountId         String
  platform          Platform
  platformMentionId String?
  authorUsername    String
  authorDisplayName String?
  content           String
  mentionType       MentionType
  sourceUrl         String?
  detectedAt        DateTime    @default(now())
  read              Boolean     @default(false)
  responded         Boolean     @default(false)

  account Account @relation(fields: [accountId], references: [id])

  @@index([accountId, detectedAt])
  @@map("mentions")
}

enum MentionType {
  MENTION
  REPLY
  QUOTE
  DM
}

model InboxItem {
  id            String    @id @default(cuid())
  accountId     String
  platform      Platform
  itemType      InboxType
  fromUsername  String
  content       String
  threadContext String?
  receivedAt    DateTime  @default(now())
  read          Boolean   @default(false)
  archived      Boolean   @default(false)
  replied       Boolean   @default(false)
  assignedTo    String?
  internalNotes String?

  account Account @relation(fields: [accountId], references: [id])

  @@index([accountId, receivedAt])
  @@index([read, archived])
  @@map("inbox_items")
}

enum InboxType {
  COMMENT
  DM
  MENTION
}

// ============================================================
// SOCIAL LISTENING
// ============================================================

model ListeningTopic {
  id                  String       @id @default(cuid())
  name                String
  description         String?
  createdById         String
  createdAt           DateTime     @default(now())
  active              Boolean      @default(true)
  pollingTier         PollingTier  @default(WARM)
  pollingTierOverride PollingTier?

  queries    ListeningQuery[]
  hits       ListeningHit[]
  subreddits MonitoredSubreddit[]

  @@map("listening_topics")
}

enum PollingTier {
  HOT
  WARM
  COOL
  SCHEDULED
}

model ListeningQuery {
  id               String    @id @default(cuid())
  topicId          String
  platform         Platform
  queryString      String
  negativeKeywords String[]  @default([])
  subreddits       String[]  @default([])
  generatedBy      String    @default("manual") // "ai" | "manual"
  active           Boolean   @default(true)
  estDailyVolume   Int?
  estMonthlyCost   Float?
  totalHits        Int       @default(0)
  actionableHits   Int       @default(0)
  spamHits         Int       @default(0)
  dismissedHits    Int       @default(0)
  avgHeuristic     Float?
  lastEvaluatedAt  DateTime?

  topic ListeningTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  hits  ListeningHit[]

  @@map("listening_queries")
}

model ListeningHit {
  id                     String     @id @default(cuid())
  queryId                String
  topicId                String
  accountId              String?
  platform               Platform
  platformPostId         String?
  authorUsername         String
  authorDisplayName      String?
  authorProfileImageUrl  String?
  authorFollowersOrKarma Int?
  content                String
  sourceUrl              String?
  subreddit              String?
  parentThreadTitle      String?
  detectedAt             DateTime   @default(now())
  engagementCount        Int        @default(0)
  heuristicScore         Float      @default(0)
  aiRelevance            Relevance?
  sentiment              Sentiment?
  sentimentConfidence    Float?
  isActionable           Boolean    @default(false)
  dismissed              Boolean    @default(false)
  dismissedBy            String?
  dismissReason          String?
  routedToInboxItemId    String?

  query   ListeningQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)
  topic   ListeningTopic @relation(fields: [topicId], references: [id])
  account Account?       @relation(fields: [accountId], references: [id])

  @@index([topicId, detectedAt])
  @@index([sentiment, detectedAt])
  @@map("listening_hits")
}

enum Relevance {
  HIGH
  MEDIUM
  LOW
  SPAM
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

model MonitoredSubreddit {
  id            String  @id @default(cuid())
  topicId       String
  subredditName String
  suggestedBy   String  @default("manual")
  active        Boolean @default(true)
  avgDailyPosts Int?
  avgEngagement Float?

  topic   ListeningTopic     @relation(fields: [topicId], references: [id], onDelete: Cascade)
  metrics SubredditMetrics[]

  @@unique([topicId, subredditName])
  @@map("monitored_subreddits")
}

model SubredditMetrics {
  id          String   @id @default(cuid())
  subredditId String
  date        DateTime @db.Date

  subscribers   Int     @default(0)
  postsCount    Int     @default(0)
  commentsCount Int     @default(0)
  avgUpvotes    Float   @default(0)
  avgComments   Float   @default(0)
  topPostScore  Int     @default(0)
  topPostTitle  String?

  subreddit MonitoredSubreddit @relation(fields: [subredditId], references: [id], onDelete: Cascade)

  @@unique([subredditId, date])
  @@map("subreddit_metrics")
}

// ============================================================
// COMPETITORS
// ============================================================

model Competitor {
  id          String   @id @default(cuid())
  name        String
  createdById String
  createdAt   DateTime @default(now())

  accounts   CompetitorAccount[]
  keywords   CompetitorKeyword[]
  metrics    CompetitorMetrics[]
  posts      CompetitorPost[]
  amplifiers CompetitorAmplifier[]

  @@map("competitors")
}

model CompetitorAccount {
  id             String   @id @default(cuid())
  competitorId   String
  platform       Platform
  username       String
  platformUserId String?

  competitor Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@map("competitor_accounts")
}

model CompetitorKeyword {
  id           String @id @default(cuid())
  competitorId String
  keyword      String

  competitor Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@map("competitor_keywords")
}

model CompetitorMetrics {
  id           String   @id @default(cuid())
  competitorId String
  date         DateTime @db.Date

  followersX           Int   @default(0)
  followersReddit      Int   @default(0)
  karmaReddit          Int   @default(0)
  postsCount           Int   @default(0)
  avgEngagementRate    Float @default(0)
  mentionCount         Int   @default(0)
  sentimentPositivePct Float @default(0)
  shareOfVoicePct      Float @default(0)

  competitor Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@unique([competitorId, date])
  @@map("competitor_metrics")
}

model CompetitorPost {
  id             String   @id @default(cuid())
  competitorId   String
  platform       Platform
  platformPostId String
  content        String
  contentType    String   @default("POST") // POST, THREAD, ARTICLE
  authorUsername String
  postedAt       DateTime
  fetchedAt      DateTime @default(now())

  // Engagement metrics at time of fetch
  likes          Int   @default(0)
  retweets       Int   @default(0)
  replies        Int   @default(0)
  quotes         Int   @default(0)
  impressions    Int   @default(0)
  engagementRate Float @default(0)

  competitor Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@unique([competitorId, platformPostId])
  @@index([competitorId, postedAt])
  @@map("competitor_posts")
}

model CompetitorAmplifier {
  id                     String   @id @default(cuid())
  competitorId           String
  platform               Platform
  username               String
  platformUserId         String?
  displayName            String?
  avatarUrl              String?
  followersCount         Int      @default(0)
  amplificationType      String // comma-separated: "RETWEET,QUOTE,MENTION"
  interactionCount       Int      @default(0)
  engagementContribution Int      @default(0)
  firstSeenAt            DateTime @default(now())
  lastSeenAt             DateTime @default(now())

  competitor Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@unique([competitorId, platform, username])
  @@index([competitorId, interactionCount])
  @@map("competitor_amplifiers")
}

// ============================================================
// KOL TRACKING
// ============================================================

model KOL {
  id                      String           @id @default(cuid())
  name                    String
  platform                Platform
  username                String
  platformUserId          String?
  avatarUrl               String?
  bio                     String?
  location                String?
  verified                Boolean          @default(false)
  followingCount          Int?
  accountCreatedAt        DateTime?
  websiteUrl              String?
  profileSummary          String? // AI-generated JSON narrative
  profileSummaryUpdatedAt DateTime?
  profileEnrichedAt       DateTime? // Last API enrichment timestamp
  relationshipType        RelationshipType
  cohortId                String?
  compensationMonthly     Float?
  campaignDeliverables    Json?
  baselineFollowers       Int?
  baselineEngRate         Float?
  aiScore                 String? // A-F
  aiScoreRationale        String?
  aiScoreUpdatedAt        DateTime?
  addedBy                 String
  createdAt               DateTime         @default(now())
  active                  Boolean          @default(true)

  cohort      KOLCohort?      @relation(fields: [cohortId], references: [id])
  activations KOLActivation[]
  metrics     KOLMetrics[]

  @@map("kols")
}

enum RelationshipType {
  PAID_PARTNER
  ORGANIC_ADVOCATE
  ADVISOR
  PORTFOLIO_FOUNDER
  RETAIL_ANALYST
  COMPANY_EXEC
}

model KOLCohort {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdBy   String
  createdAt   DateTime @default(now())

  kols KOL[]

  @@map("kol_cohorts")
}

model KOLActivation {
  id                 String         @id @default(cuid())
  kolId              String
  platform           Platform
  activationType     ActivationType
  platformPostId     String?
  content            String?
  sourceUrl          String?
  postedAt           DateTime?
  detectedAt         DateTime       @default(now())
  detectionMethod    String?
  campaignId         String?
  sentiment          Sentiment?
  metricsAtDetection Json?
  metricsAt24h       Json?
  metricsAt48h       Json?
  metricsAt7d        Json?

  kol KOL @relation(fields: [kolId], references: [id], onDelete: Cascade)

  @@index([kolId, detectedAt])
  @@map("kol_activations")
}

enum ActivationType {
  DIRECT_MENTION
  RETWEET
  QUOTE_TWEET
  REPLY
  THREAD
  SUBREDDIT_POST
  COMMENT
  ORGANIC_ADVOCACY
}

model KOLMetrics {
  id        String   @id @default(cuid())
  kolId     String
  weekStart DateTime @db.Date

  followers                  Int     @default(0)
  engagementRateBrand        Float   @default(0)
  engagementRateBaseline     Float   @default(0)
  activationsCount           Int     @default(0)
  totalImpressionsEst        Int     @default(0)
  avgEngagementPerActivation Float   @default(0)
  sentimentPositivePct       Float   @default(0)
  followerGrowthCorrelation  Float   @default(0)
  aiScore                    String?
  costPerEngagement          Float?

  kol KOL @relation(fields: [kolId], references: [id], onDelete: Cascade)

  @@unique([kolId, weekStart])
  @@map("kol_metrics")
}

// ============================================================
// ALERTS & AI INSIGHTS
// ============================================================

model AlertRule {
  id          String  @id @default(cuid())
  createdById String
  name        String
  active      Boolean @default(true)
  conditions  Json // { topic, platform, relevance, sentiment, thresholds }
  actions     Json // { notify channels, assign_to, tag, priority }

  createdBy User @relation(fields: [createdById], references: [id])

  @@map("alert_rules")
}

model AIInsight {
  id             String      @id @default(cuid())
  accountId      String?
  userId         String?
  insightType    InsightType
  content        Json
  dataRangeStart DateTime?
  dataRangeEnd   DateTime?
  generatedAt    DateTime    @default(now())
  dismissed      Boolean     @default(false)
  dismissedBy    String?

  account Account? @relation(fields: [accountId], references: [id])
  user    User?    @relation(fields: [userId], references: [id])

  @@index([insightType, generatedAt])
  @@map("ai_insights")
}

enum InsightType {
  POST_DEBRIEF
  WEEKLY_SUMMARY
  DAILY_LISTENING_DIGEST
  WEEKLY_LANDSCAPE_REPORT
  OPTIMAL_SCHEDULE
  AUDIENCE_INSIGHT
  CONTENT_SUGGESTION
  PERFORMANCE_PATTERN
  COMPETITOR_STRATEGY
  AUDIENCE_QUESTION
}

// ============================================================
// APPROVAL WORKFLOW
// ============================================================

model ApprovalRequest {
  id              String         @id @default(cuid())
  postId          String
  requestedById   String
  reviewedById    String?
  status          ApprovalStatus @default(PENDING)
  reviewerComment String?
  requestedAt     DateTime       @default(now())
  reviewedAt      DateTime?

  post        Post              @relation(fields: [postId], references: [id], onDelete: Cascade)
  requestedBy User              @relation("approvalRequester", fields: [requestedById], references: [id])
  reviewer    User?             @relation("reviewer", fields: [reviewedById], references: [id])
  comments    ApprovalComment[]

  @@index([status])
  @@map("approval_requests")
}

model ApprovalComment {
  id                String   @id @default(cuid())
  approvalRequestId String
  authorName        String
  content           String
  source            String   @default("app") // "app" | "notion"
  notionCommentId   String? // For dedup during Notion sync
  createdAt         DateTime @default(now())

  approvalRequest ApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)

  @@index([approvalRequestId])
  @@map("approval_comments")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  CHANGES_REQUESTED
  REJECTED
}

// ============================================================
// REPORTS
// ============================================================

model Report {
  id              String       @id @default(cuid())
  title           String
  reportType      ReportType
  prompt          String? // NLP prompt used to generate
  content         Json // Generated report data
  aiPct           Float        @default(0) // Percentage AI-generated
  createdById     String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  downloads       Int          @default(0)
  status          ReportStatus @default(READY)
  chartUrls       Json? // Array of { id, label, imageUrl } objects
  coveragePeriod  Json? // { start: string, end: string } ISO date range
  benchmarkPeriod Json? // { start: string, end: string } or null

  deliveries ReportDelivery[]

  @@map("reports")
}

model ReportDelivery {
  id         String   @id @default(cuid())
  reportId   String
  channel    String // 'EMAIL' or 'PDF_DOWNLOAD'
  recipients Json     @default("[]") // JSON array of email strings
  status     String // 'SENT' or 'FAILED'
  error      String?
  createdAt  DateTime @default(now())
  report     Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("report_deliveries")
}

enum ReportType {
  WEEKLY_PERFORMANCE
  MONTHLY_SUMMARY
  COMPETITIVE_ANALYSIS
  KOL_REPORT
  CUSTOM
}

enum ReportStatus {
  GENERATING
  READY
  FAILED
}

// ============================================================
// COPILOT (Content Co-Pilot)
// ============================================================

model CopilotThread {
  id        String   @id @default(cuid())
  userId    String
  accountId String?
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages CopilotMessage[]

  @@index([userId, updatedAt])
  @@map("copilot_threads")
}

model CopilotMessage {
  id        String   @id @default(cuid())
  threadId  String
  role      String
  content   String
  metadata  Json?
  createdAt DateTime @default(now())

  thread CopilotThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@map("copilot_messages")
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  target    String?
  metadata  Json?
  ipAddress String?
  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, timestamp])
  @@index([action, timestamp])
  @@map("audit_logs")
}

// ============================================================
// API CALL TRACKING (Cost Management)
// ============================================================

model APICallLog {
  id            String   @id @default(cuid())
  provider      String // "x_official", "twitterapi_io", "reddit", "claude"
  endpoint      String
  method        String
  statusCode    Int
  responseTime  Int // ms
  tokensUsed    Int? // For Claude API
  estimatedCost Float    @default(0)
  accountId     String?
  timestamp     DateTime @default(now())

  @@index([provider, timestamp])
  @@index([accountId, timestamp])
  @@map("api_call_logs")
}

// ============================================================
// CACHE METADATA (for TTL tracking)
// ============================================================

model CacheEntry {
  id        String   @id @default(cuid())
  cacheKey  String   @unique
  dataType  String // "profile", "post_metrics", "mentions", "search"
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
  @@map("cache_entries")
}

// ============================================================
// TICKETS (Bug Reports & Feature Requests)
// ============================================================

model Ticket {
  id          String         @id @default(cuid())
  type        TicketType
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  title       String
  description String
  screenshots Json? // [{ url, filename }]
  createdById String
  aiAnalysis  Json? // { summary, suggestedFix, filesAffected, confidence }
  resolution  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  resolvedAt  DateTime?

  createdBy User            @relation(fields: [createdById], references: [id])
  comments  TicketComment[]

  @@index([type, status])
  @@index([createdById])
  @@map("tickets")
}

model TicketComment {
  id         String   @id @default(cuid())
  ticketId   String
  authorName String // user name or "Claude AI"
  content    String
  createdAt  DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_comments")
}

enum TicketType {
  BUG
  FEATURE_REQUEST
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  AI_REVIEWING
  RESOLVED
  WONT_FIX
  DEFERRED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ============================================================
// REPORT SCHEDULING
// ============================================================

enum Cadence {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

model ReportSchedule {
  id           String     @id @default(cuid())
  name         String
  cadence      Cadence
  reportType   ReportType @default(WEEKLY_PERFORMANCE)
  enabled      Boolean    @default(true)
  recipients   Json       @default("[]") // JSON array of email strings
  createdById  String
  nextRunAt    DateTime
  lastRunAt    DateTime?
  lastReportId String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([enabled, nextRunAt])
  @@map("report_schedules")
}

// ============================================================
// AD HOC REPORTS (Conversational Report Scoping)
// ============================================================

model AdHocReport {
  id                String               @id @default(cuid())
  title             String?
  reportId          String? // Link to generated Report
  status            String               @default("SCOPING") // SCOPING, GENERATING, READY, FAILED
  reportParams      Json? // { dateStart, dateEnd, reportType, metricsScope, comparisonBaseline }
  snapshotIntervals Json? // [24, 48] hours or null
  nextSnapshotAt    DateTime?
  createdById       String
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  messages          AdHocReportMessage[]

  @@index([createdById, updatedAt])
  @@map("adhoc_reports")
}

model AdHocReportMessage {
  id          String      @id @default(cuid())
  adHocId     String
  role        String // 'user' | 'assistant'
  content     String
  createdAt   DateTime    @default(now())
  adHocReport AdHocReport @relation(fields: [adHocId], references: [id], onDelete: Cascade)

  @@index([adHocId, createdAt])
  @@map("adhoc_report_messages")
}

// ============================================================
// MILESTONES (Benchmarking)
// ============================================================

model Milestone {
  id          String   @id @default(cuid())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([startDate, endDate])
  @@map("milestones")
}
